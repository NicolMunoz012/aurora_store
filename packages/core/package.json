{
  "name": "@aurora/core",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./users": {
      "types": "./dist/users/index.d.ts",
      "default": "./dist/users/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "default": "./dist/catalog/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing/index.d.ts",
      "default": "./dist/pricing/index.js"
    },
    "./cart": {
      "types": "./dist/cart/index.d.ts",
      "default": "./dist/cart/index.js"
    },
    "./inventory": {
      "types": "./dist/inventory/index.d.ts",
      "default": "./dist/inventory/index.js"
    },
    "./orders": {
      "types": "./dist/orders/index.d.ts",
      "default": "./dist/orders/index.js"
    },
    "./store-config": {
      "types": "./dist/store-config/index.d.ts",
      "default": "./dist/store-config/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "default": "./dist/audit/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aurora/database": "workspace:*",
    "@aurora/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
