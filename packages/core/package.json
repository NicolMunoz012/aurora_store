{
  "name": "@aurora/core",
  "version": "1.0.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./auth": {
      "types": "./auth/index.ts",
      "default": "./auth/index.ts"
    },
    "./users": {
      "types": "./users/index.ts",
      "default": "./users/index.ts"
    },
    "./catalog": {
      "types": "./catalog/index.ts",
      "default": "./catalog/index.ts"
    },
    "./pricing": {
      "types": "./pricing/index.ts",
      "default": "./pricing/index.ts"
    },
    "./cart": {
      "types": "./cart/index.ts",
      "default": "./cart/index.ts"
    },
    "./inventory": {
      "types": "./inventory/index.ts",
      "default": "./inventory/index.ts"
    },
    "./orders": {
      "types": "./orders/index.ts",
      "default": "./orders/index.ts"
    },
    "./store-config": {
      "types": "./store-config/index.ts",
      "default": "./store-config/index.ts"
    },
    "./audit": {
      "types": "./audit/index.ts",
      "default": "./audit/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aurora/database": "workspace:*",
    "@aurora/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
